(print "=== Math ===")
(print "(+ 1 1) -> " (+ 1 1))
(print "(- 1 1) -> " (- 1 1))
(print "(* 1 1) -> " (* 1 1))

(print "=== Logical OR ===")
(print "t t ->"(or 1 1))
(print "t f ->"(or 1 nil))
(print "f t ->"(or nil 1))
(print "f f ->"(or nil nil))

(print "=== Logical And ===")
(print "t t ->"(and 1 1))
(print "t f ->"(and 1 nil))
(print "f t ->"(and nil 1))
(print "f f ->"(and nil nil))

